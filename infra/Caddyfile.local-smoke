{
	auto_https off
}

:80 {
	encode zstd gzip

	handle /api/* {
		uri strip_prefix /api
		reverse_proxy api:8787
	}

	handle /mcp* {
		reverse_proxy api:8787
	}

	handle /.well-known/oauth-protected-resource {
		root * /srv/web
		header Content-Type application/json
		file_server
	}

	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}
