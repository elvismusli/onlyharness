{
	email admin@superskill.sh
	servers {
		trusted_proxies static private_ranges
		trusted_proxies_strict
	}
}

(superskill_machine_routes) {
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy api:8787
	}

	handle /mcp* {
		reverse_proxy api:8787
	}

	handle /.well-known/oauth-protected-resource {
		root * /srv/web
		header Content-Type application/json
		file_server
	}

	handle /.well-known/oauth-authorization-server {
		header Cache-Control "no-store"
		respond 404
	}

	handle /.well-known/mcp-registry-auth {
		root * /srv/web
		header Content-Type text/plain
		file_server
	}

	# Existing MCP Registry coordinates and installed clients may still fetch
	# this machine-readable file from onlyharness.com during compatibility.
	handle /server.json {
		root * /srv/web
		header Content-Type application/json
		file_server
	}
}

www.superskill.sh {
	redir https://superskill.sh{uri} permanent

	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
}

superskill.sh {
	encode zstd gzip
	log {
		output stdout
		format filter {
			request>remote_ip ip_mask 16 32
			request>client_ip ip_mask 16 32
			request>headers>X-Forwarded-For ip_mask 16 32
			request>uri regexp "\\?.*$" ""
			wrap json {
				time_format rfc3339_nano
				duration_format ms
			}
		}
	}
	import superskill_machine_routes

	@share_preview path /r/* /c/* /w/* /og/*
	handle @share_preview {
		reverse_proxy api:8787
	}

	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}

onlyharness.com, www.onlyharness.com {
	encode zstd gzip
	import superskill_machine_routes

	# Only machine compatibility endpoints stay on the legacy origin. Human
	# pages move permanently to the single SuperSkill product surface.
	handle {
		redir https://superskill.sh{uri} permanent
	}
}
