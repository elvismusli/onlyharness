{
  "name": "@harnesshub/capability-schema",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./browser": {
      "types": "./src/browser.ts",
      "runtime-built": "./dist/browser.js",
      "default": "./src/browser.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "runtime-built": "./dist/node.js",
      "default": "./src/node.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
